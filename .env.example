# Plantilla de variables de entorno. Copia este archivo a `.env` y ajusta los valores.
# Expo incrusta las variables EXPO_PUBLIC_* DENTRO del APK al compilar (no se leen en
# tiempo de ejecución): si cambias la URL, recompila / reinicia Expo con --clear.

# Origen del backend HatoSync-Api. Elige según tu entorno:
#   Emulador Android          → http://10.0.2.2:8000
#   Celular en la misma Wi-Fi → http://<IP-LAN>:8000   (ej. http://192.168.0.7:8000)
#   Simulador iOS / web       → http://127.0.0.1:8000
#   Túnel público (ngrok)     → https://<tu-subdominio>.ngrok-free.dev
EXPO_PUBLIC_API_ORIGIN=http://10.0.2.2:8000
