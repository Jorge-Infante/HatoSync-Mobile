{
  "expo": {
    "name": "HatoSync",
    "slug": "HatoSync-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#FDFCF8",
      "barStyle": "dark-content"
    },
    "android": {
      "package": "com.hatosync.mobile",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "HatoSync usa tus fotos para registrar imágenes de los animales.",
          "cameraPermission": "HatoSync usa la cámara para tomar fotos de los animales."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "HatoSync organiza en tu galería las fotos que tomas de los animales.",
          "savePhotosPermission": "HatoSync guarda las fotos que tomas en la carpeta HatoSync de tu galería."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "HatoSync usa la cámara para leer las chapetas QR de los animales."
        }
      ],
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "reactNativeArchitectures": ["armeabi-v7a", "arm64-v8a"]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 168,
          "resizeMode": "contain",
          "backgroundColor": "#F5F3EB"
        }
      ],
      "expo-font",
      "expo-image",
      "onnxruntime-react-native",
      "./plugins/withOnnxruntimePackage.js",
      "./plugins/withShortCxxPath.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2E7D32"
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "HatoSync usa tu ubicación para centrar el mapa de potreros en donde estás."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f452d988-942e-4bd8-a389-9a089a5a920d"
      }
    }
  }
}
